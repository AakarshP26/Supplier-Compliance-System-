# Anthropic API key for LLM-based risk extraction.
# Get one at https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Set USE_MOCK_LLM=1 to use deterministic mock responses instead of calling
# the real API. Useful for offline demos and avoiding rate limits.
USE_MOCK_LLM=1

# Path to data directory (override only if running from outside repo root)
SCS_DATA_DIR=./data
